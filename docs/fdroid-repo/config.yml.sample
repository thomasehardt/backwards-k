# Real config.yml (gitignored — contains secrets) is generated locally via:
#   fdroid init --no-prompt --android-home /path/to/Android/Sdk \
#     -d "CN=Your Repo Name, OU=F-Droid, C=US"
# then hand-edit in the non-secret fields below. Never commit the real
# config.yml or keystore.p12 — see .gitignore and the warning in CLAUDE.md.

sdk_path: /path/to/Android/Sdk
keystore: keystore.p12
keydname: CN=..., OU=F-Droid
keystorepass: <generated by fdroid init, keep secret>
keypass: <generated by fdroid init, keep secret>
repo_keyalias: <generated by fdroid init>

repo_url: https://thomasehardt.github.io/backwards-k/fdroid-repo/repo
repo_name: Backwards K F-Droid Repo
repo_description: >-
  Personal F-Droid repo for Backwards K, a mobile baseball scorecard app.
  AI co-authored (see the app's own description and the project README).
archive_older: 3
repo_icon: icon.png
