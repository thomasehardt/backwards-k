{"repo": {"name": {"en-US": "My First F-Droid Archive Demo"}, "description": {"en-US": "These are the apps that have been archived from the main repo."}, "icon": {"en-US": {"name": "/icons/icon.png", "sha256": "aaea9fa5ec6fd424f623a94545deee7df18e939de63d34ba4d137e1705cea130", "size": 49759}}, "address": "https://thomasehardt.github.io/backwards-k/fdroid-repo/archive", "timestamp": 1783782266000, "categories": {"Sports": {"name": {"en-US": "Sports"}}}}, "packages": {"com.backwardsk.app": {"metadata": {"added": 1783752439000, "categories": ["Sports"], "changelog": "https://github.com/thomasehardt/backwards-k/commits/main", "issueTracker": "https://github.com/thomasehardt/backwards-k/issues", "lastUpdated": 1783782265000, "license": "MIT", "sourceCode": "https://github.com/thomasehardt/backwards-k", "webSite": "https://github.com/thomasehardt/backwards-k", "authorName": "Thomas Ehardt", "name": {"en-US": "Backwards K"}, "summary": {"en-US": "Mobile baseball scorecard, digitizing the paper scoring notation"}, "description": {"en-US": "This app was co-authored by an AI agent (Claude, by Anthropic), directed\nand reviewed by a human. See the project's source repository and git\nhistory for the full record of what was generated versus human-directed.\n\nBackwards K is a mobile-first digital scorecard for keeping score at a\nbaseball game — built to replace the paper scorecard, not simplify away\nfrom it. It follows the same notation experienced scorers already use,\nincluding the notation the app is named after: a backwards K for a\ncalled third strike.\n\nFeatures:\n\n* Live scoring with the full paper-scorecard result vocabulary, including\n  fielder assist sequences (6-3, 4-6-3, ...)\n* Automatic runs/RBI, derived from a baserunning simulation rather than\n  manual entry\n* Automatic box score, including errors\n* Multiple games saved locally, browsable from a Games tab\n* Optional MLB Stats API sync to pull a real game's lineups and\n  play-by-play into the scorecard\n* Non-LLM play-by-play recap generation from a finished game\n* Fully offline once installed — no accounts, no tracking\n"}, "preferredSigner": "00d47d8ade88f0cba60b4903388a6061068861b812844bb0d4dccc6e0bd53af2"}, "versions": {"a64c1af2e80094af9942b1c0dde01978f4f85aa84abb74e97eab35453b8fb416": {"added": 1783777875000, "file": {"name": "/com.backwardsk.app_3004.apk", "sha256": "a64c1af2e80094af9942b1c0dde01978f4f85aa84abb74e97eab35453b8fb416", "size": 3446284}, "manifest": {"versionName": "0.3.0-alpha.4", "versionCode": 3004, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["00d47d8ade88f0cba60b4903388a6061068861b812844bb0d4dccc6e0bd53af2"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.backwardsk.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "1fbd2654fc0148bbdc0de8f97aeedf87ff8df9b8e066e7b308fe308435928b06": {"added": 1783775940000, "file": {"name": "/com.backwardsk.app_3003.apk", "sha256": "1fbd2654fc0148bbdc0de8f97aeedf87ff8df9b8e066e7b308fe308435928b06", "size": 3444580}, "manifest": {"versionName": "0.3.0-alpha.3", "versionCode": 3003, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["00d47d8ade88f0cba60b4903388a6061068861b812844bb0d4dccc6e0bd53af2"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.backwardsk.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "c139e5f57e493009a6ae3fd57fbf921b33a9ff8ef0ba0267e3d0b8980fdcccf7": {"added": 1783773914000, "file": {"name": "/com.backwardsk.app_3000.apk", "sha256": "c139e5f57e493009a6ae3fd57fbf921b33a9ff8ef0ba0267e3d0b8980fdcccf7", "size": 3444476}, "manifest": {"versionName": "0.3.0-alpha.2", "versionCode": 3000, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["00d47d8ade88f0cba60b4903388a6061068861b812844bb0d4dccc6e0bd53af2"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "com.backwardsk.app.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "d7